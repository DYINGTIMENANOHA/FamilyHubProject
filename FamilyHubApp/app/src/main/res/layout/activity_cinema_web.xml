<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/cinema_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#121212"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingTop="6dp"
        android:paddingEnd="10dp"
        android:paddingBottom="6dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cinema_close"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="48dp"
            android:layout_height="44dp"
            android:minWidth="48dp"
            android:text="X"
            android:textAllCaps="false" />

        <TextView
            android:id="@+id/cinema_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/familyhub_cinema"
            android:textColor="#FFFFFF"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cinema_rotate"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginEnd="8dp"
            android:minWidth="72dp"
            android:text="@string/familyhub_landscape"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cinema_refresh"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:minWidth="80dp"
            android:text="@string/familyhub_refresh"
            android:textAllCaps="false" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/cinema_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:max="100"
        android:visibility="gone" />

    <WebView
        android:id="@+id/cinema_webview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fadeScrollbars="false"
        android:overScrollMode="ifContentScrolls"
        android:scrollbarStyle="outsideOverlay"
        tools:ignore="SetJavaScriptEnabled" />
</LinearLayout>
